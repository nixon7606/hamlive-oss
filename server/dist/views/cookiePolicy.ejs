<!DOCTYPE html>
<html lang="en">
<!-- hamlive-oss — MIT License. See LICENSE. -->

<head>
  <%- include('./partials/head') %> <%- include('./partials/pageTopFeatures') %>

  <title><%= server.appName %> - Cookie Policy <%if (server.logLevel !== "info") {%> (<%= server.logLevel %>) <%}%></title>
    </head>

    <body class="bg-dark text-light">
      <%- include('./partials/adTopBar') %>
    <%- include('./partials/navbar', {user: user}) %>

    <div class="container">
      <div class="row">
        <div class="col p-md-2 m-md-3">
          <h1 class="h3 mt-3">Cookie Policy</h1>

          <div class="alert alert-warning mt-3" role="alert">
            <strong>Operator action required.</strong> This is a placeholder. Replace the contents of
            <code>server/dist/views/cookiePolicy.ejs</code> with a cookie policy describing the
            cookies <em>your</em> instance sets.
          </div>

          <p class="mt-3">
            For reference, this application uses a single signed, HTTP-only session cookie to keep
            you logged in. It does not set third-party advertising cookies by default. Enabling
            optional integrations (e.g. embedded chat) may introduce additional cookies governed by
            those providers.
          </p>
        </div>
      </div>
    </div>

    <%- include('./partials/pageBottomFeatures') %>
    </body>
    <%- include('./partials/footer') %>

</html>
