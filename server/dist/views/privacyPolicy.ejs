<!DOCTYPE html>
<html lang="en">
<!-- hamlive-oss — MIT License. See LICENSE. -->

<head>
  <%- include('./partials/head') %> <%- include('./partials/pageTopFeatures') %>

  <title><%= server.appName %> - Privacy Policy <%if (server.logLevel !== "info") {%> (<%= server.logLevel %>) <%}%></title>
    </head>

    <body class="bg-dark text-light">
      <%- include('./partials/adTopBar') %>
    <%- include('./partials/navbar', {user: user}) %>

    <div class="container">
      <div class="row">
        <div class="col p-md-2 m-md-3">
          <h1 class="h3 mt-3">Privacy Policy</h1>

          <div class="alert alert-warning mt-3" role="alert">
            <strong>Operator action required.</strong> This is a placeholder. If you host this
            application for your club or group, replace the contents of
            <code>server/dist/views/privacyPolicy.ejs</code> with your own privacy policy describing
            how <em>your</em> instance collects, uses, and stores member data.
          </div>

          <p class="mt-3">
            This open-source edition does not ship a legal privacy policy. The original hosted
            service's policy was specific to its operator and is intentionally not included. You are
            responsible for providing a policy appropriate to your jurisdiction and to the
            third-party services you enable (database host, email provider, chat provider, callsign
            lookup, geocoding, etc.).
          </p>
        </div>
      </div>
    </div>

    <%- include('./partials/pageBottomFeatures') %>
    </body>
    <%- include('./partials/footer') %>

</html>
