<!DOCTYPE html>
<html lang="en">
<!-- hamlive-oss — MIT License. See LICENSE. -->

<head>
  <%- include('./partials/head') %> <%- include('./partials/pageTopFeatures') %>

  <title><%= server.appName %> - Waiting... <%if (server.logLevel !== "info") {%> (<%= server.logLevel %>) <%}%></title>
    </head>
    <body class="bg-dark">
      <%- include('./partials/adTopBar') %>
    <%- include('./partials/navbar', {user: user}) %>

    <div class="container-fluid">
      <div class="mt-20 pt-20 d-flex justify-content-center align-items-center netwait">
        <div>
          <span class="align-middle text-light" id="netTitle" style="font-size: 1.8em"></span>
          <span class="text-tertiary align-bottom">
            <% if (user && !PERM) { %>
            <i class="bi bi-star favicon pt-2" style="font-size: 1.8em" id="fav-<%= NPID %>"></i>
            <%} else { %>
            <i class="d-none bi bi-star favicon pt-2" style="font-size: 1.8em" id="fav-<%= NPID %>"></i>
            <% } %>
          </span>

          <p class="text-secondary mt-md-3">
            <em>Waiting For Net Start...</em>
            <span class="spinner-grow spinner-grow-sm text-primary"></span>
          </p>
        </div>
      </div>
    </div>

    <%- include('./partials/pageBottomFeatures') %>

    <script src="/js/byView/<%= VIEW %>/main.js" type="module"></script>
    </body>
    <%- include('./partials/footer') %>

</html>