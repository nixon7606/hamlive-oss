{
    "name": "hamlive-oss",
    "imports": {
        "#@client/*": "./client/dist/public/js/*",
        "#@server/*": "./server/dist/*"
    },
    "version": "1.0.0",
    "main": "server/dist/server.js",
    "description": "Ham.Live — self-hostable web app for running amateur radio nets (open-source edition)",
    "scripts": {
        "start": "node server/dist/server.js",
        "setup": "node ./scripts/setup.js",
        "mongo:dev": "node ./scripts/devMongo.js",
        "gen-certs": "openssl req -x509 -newkey rsa:2048 -nodes -keyout server/dist/ssl/dev-server_key.pem -out server/dist/ssl/dev-server_cert.pem -days 3650 -subj \"/CN=localhost/O=hamlive-oss dev\" -addext \"subjectAltName=DNS:localhost,IP:127.0.0.1\"",
        "build": "tsc -p server/tsconfig.json && tsc -p client/tsconfig.json",
        "dev": "node ./scripts/dev.js",
        "test": "jest",
        "dev:watch": "cross-env NODE_ENV=development concurrently --kill-others \"tsc -p server/tsconfig.json -w\" \"tsc -p client/tsconfig.json -w\" \"nodemon --delay 2.5 server/dist/server.js\"",
        "sync:types": "node -e \"require('fs').copyFileSync('client/src/public/js/types/commonTypesupport.ts','server/src/types/commonTypesupport.ts')\""
    },
    "author": "Sean Lynch",
    "license": "MIT",
    "dependencies": {
        "@foundernest/namecase": "^1.0.5",
        "@sendgrid/eventwebhook": "^8.0.0",
        "@sendgrid/mail": "^8.1.6",
        "ap-style-title-case": "^2.0.0",
        "axios": "^1.18.0",
        "bootstrap": "~5.3.8",
        "cookie-session": "^2.1.1",
        "dotenv": "^17.4.2",
        "ejs": "^6.0.1",
        "es6-dynamic-template": "^2.0.0",
        "express": "^5.2.1",
        "express-list-endpoints": "^7.1.1",
        "express-rate-limit": "^8.5.2",
        "express-sse-ts": "^1.0.2",
        "fast-xml-parser": "^5.9.2",
        "gravatar": "^1.8.2",
        "helmet": "^8.2.0",
        "humanize-duration": "^3.33.2",
        "lodash": "^4.18.1",
        "mongoose": "^9.7.0",
        "mongoose-type-email": "^1.1.2",
        "mongoose-unique-validator": "^6.1.1",
        "multer": "^2.2.0",
        "node-cache": "^5.1.2",
        "node-color-log": "^14.0.0",
        "node-json-logger": "^0.3.0",
        "object-hash": "^3.0.0",
        "passport": "^0.7.0",
        "passport-google-oauth20": "^2.0.0",
        "passport-magic-login": "^1.2.4",
        "response-time": "^2.3.4",
        "sanitize-html": "^2.17.5",
        "slugify": "^1.6.9",
        "validator": "^13.15.35",
        "yaml": "^2.9.0"
    },
    "devDependencies": {
        "@types/bootstrap": "^5.2.11",
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/lodash": "^4.17.24",
        "@types/object-hash": "^3.0.6",
        "@types/supertest": "^7.2.0",
        "@types/yargs": "^17.0.35",
        "concurrently": "^10.0.3",
        "cross-env": "^10.1.0",
        "eslint": "^10.5.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-config-standard-with-typescript": "^43.0.1",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-n": "^18.1.0",
        "eslint-plugin-prettier": "^5.5.6",
        "eslint-plugin-promise": "^7.3.0",
        "immer": "^11.1.8",
        "jest": "^30.4.2",
        "mongodb-memory-server": "^11.2.0",
        "nodemon": "^3.1.14",
        "prettier": "^3.8.4",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.11",
        "typescript": "^6.0.3",
        "yargs": "^18.0.0"
    }
}
