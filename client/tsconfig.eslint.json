{
    // This is a separate ESLint-specific TypeScript configuration.
    // It was created because ESLint needs to lint `types.d.ts`,
    // which is in the `dist` directory and not included in the base `tsconfig.json (as all of dist is excluded)`.
    // We keep `types.d.ts` in `dist` so its sourcemaps are in the client public doc root.
    // This configuration extends the base `tsconfig.json` and includes `types.d.ts`.
    // This allows ESLint to lint it while TypeScript uses the base `tsconfig.json`.
    "extends": "./tsconfig.json",
    "include": ["src/**/*", "dist/public/js/shared/types.d.ts"],
    "exclude": ["node_modules", "**/*.spec.ts"]
}
